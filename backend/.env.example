APP_NAME=AI SOC Platform
APP_VERSION=1.0.0
DEBUG=true

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aisoc

SECRET_KEY=ChangeThisToALongRandomSecretKey123!
ACCESS_TOKEN_EXPIRE_MINUTES=480

REDIS_URL=redis://localhost:6379/0

# Optional: Add your Anthropic API key for AI generation
ANTHROPIC_API_KEY=your-key-here

# SOC tool endpoints inside Docker
WAZUH_API_URL=https://wazuh.manager:55000
MISP_URL=https://misp
THEHIVE_URL=http://thehive:9000
GRAFANA_URL=http://grafana:3000
PROMETHEUS_URL=http://prometheus:9090

# Browser launch URLs shown to administrators
WAZUH_PUBLIC_URL=https://localhost:8443
MISP_PUBLIC_URL=https://localhost:10443
THEHIVE_PUBLIC_URL=http://localhost:9000
GRAFANA_PUBLIC_URL=http://localhost:3001
PROMETHEUS_PUBLIC_URL=http://localhost:9090
