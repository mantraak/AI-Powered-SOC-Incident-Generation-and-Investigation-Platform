APP_NAME=Romulus
APP_VERSION=1.0.0
DEBUG=true

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aisoc

SECRET_KEY=ChangeThisToALongRandomSecretKey123!
ACCESS_TOKEN_EXPIRE_MINUTES=480

REDIS_URL=redis://localhost:6379/0

# Optional environment fallback. Prefer Admin > AI Settings.
NVIDIA_API_KEY=your-new-rotated-key-here
AI_API_ENDPOINT=https://integrate.api.nvidia.com/v1/chat/completions
AI_MODEL=meta/llama-3.3-70b-instruct

# AI Moderator public-source limits
MODERATOR_MAX_LINKS=4
MODERATOR_MAX_SOURCE_CHARS=12000
MODERATOR_MAX_DOWNLOAD_BYTES=2000000

# SOC tool endpoints inside Docker
WAZUH_API_URL=https://wazuh.manager:55000
MISP_URL=https://misp
THEHIVE_URL=http://thehive:9000
GRAFANA_URL=http://grafana:3000
PROMETHEUS_URL=http://prometheus:9090

# Browser launch URLs shown to administrators
WAZUH_PUBLIC_URL=https://localhost:48173/wazuh
MISP_PUBLIC_URL=https://localhost:48173/misp
THEHIVE_PUBLIC_URL=https://localhost:48173/thehive
GRAFANA_PUBLIC_URL=https://localhost:48173/grafana
PROMETHEUS_PUBLIC_URL=https://localhost:48173/prometheus

# Pinned MITRE ATT&CK Enterprise catalogue
MITRE_ATTACK_VERSION=19.1
MITRE_STIX_URL=https://raw.githubusercontent.com/mitre-attack/attack-stix-data/master/enterprise-attack/enterprise-attack-19.1.json
MITRE_CATALOG_PATH=/app/data/mitre/catalog.json
MITRE_FORCE_SYNC=false
