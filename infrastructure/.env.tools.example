# Copy to infrastructure/.env.tools before starting the stack.
# Development defaults are intentionally easy to rotate; never expose them publicly.
TZ=Asia/Kolkata

# Wazuh 4.14.5
WAZUH_VERSION=4.14.5
WAZUH_INDEXER_PASSWORD=SecretPassword
WAZUH_API_PASSWORD=MyS3cr37P450r.*-
WAZUH_DASHBOARD_PORT=8443
WAZUH_INDEXER_PORT=9200

# MISP 2.5
MISP_CORE_TAG=v2.5.42
MISP_MODULES_TAG=v3.0.8
MISP_BASE_URL=https://localhost:10443
MISP_HTTPS_PORT=10443
MISP_ADMIN_EMAIL=admin@admin.test
MISP_ADMIN_PASSWORD=ChangeMe-MISP-2026!
MISP_ADMIN_KEY=0123456789abcdef0123456789abcdef01234567
MISP_DB_PASSWORD=ChangeMeMispDb2026
MISP_DB_ROOT_PASSWORD=ChangeMeMispRoot2026
MISP_REDIS_PASSWORD=ChangeMe-MISP-Redis-2026

# TheHive 5
THEHIVE_VERSION=5.7.3
THEHIVE_PORT=9000
THEHIVE_SECRET=change-me-to-a-random-string-at-least-32-characters
